{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the RetireSim AI application.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique Firebase Auth ID." },
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "photoURL": { "type": "string", "format": "uri" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Simulation": {
      "title": "Simulation",
      "description": "A saved retirement simulation record.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "params": { "type": "object", "description": "The input parameters for the simulation." },
        "metrics": { "type": "object", "description": "The calculated results (success rate, readiness score, etc.)." },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "params", "metrics", "createdAt"]
    },
    "Scenario": {
      "title": "Scenario",
      "description": "A named scenario for comparison.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "simulationId": { "type": "string" },
        "metrics": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "simulationId", "metrics", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Private user profile data."
    },
    "/users/{userId}/simulations/{simId}": {
      "schema": "Simulation",
      "description": "Historical simulations for a user."
    },
    "/users/{userId}/scenarios/{scenarioId}": {
      "schema": "Scenario",
      "description": "Saved scenarios for comparison."
    }
  }
}
